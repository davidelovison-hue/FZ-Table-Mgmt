{
  "name": "fz-table-mgmt",
  "version": "0.0.0",
  "description": "Fever Zone table management prototype — GitHub Pages",
  "homepage": "https://davidelovison-hue.github.io/FZ-Table-Mgmt/",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidelovison-hue/FZ-Table-Mgmt.git"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:gh-pages": "ng serve --serve-path /FZ-Table-Mgmt/ --host 127.0.0.1 --port 4211",
    "build": "ng build",
    "build:gh-pages": "ng build --configuration production --base-href /FZ-Table-Mgmt/ && npm run gh-pages:spa-files",
    "gh-pages:spa-files": "node scripts/gh-pages-spa-files.mjs",
    "deploy:gh-pages": "npm run build:gh-pages && npx angular-cli-ghpages --dir=dist/fz-table-mgmt/browser --repo=https://github.com/davidelovison-hue/FZ-Table-Mgmt.git --branch=gh-pages",
    "preview:gh-pages": "npm run build:gh-pages && node scripts/preview-gh-pages-setup.mjs && node scripts/static-preview-server.mjs",
    "build:preview:root": "ng build --configuration production --base-href /",
    "preview:root": "npm run build:preview:root && node scripts/static-preview-root-server.mjs",
    "push-and-deploy": "git push -u origin main && npm run deploy:gh-pages",
    "bootstrap:github-repo": "bash scripts/bootstrap-new-repo.sh",
    "github:create-repo": "bash scripts/create-feverzone-guestlist-repo.sh",
    "github:setup": "bash scripts/do-create-repo-and-deploy.sh",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.2",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.2"
  }
}
